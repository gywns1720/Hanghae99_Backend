{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/gateway-server/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/gateway-server/tsconfig.app.json"
  },
  "projects": {
    "e-commerce": {
      "type": "library",
      "root": "libs/e-commerce",
      "entryFile": "index",
      "sourceRoot": "libs/e-commerce/src",
      "compilerOptions": {
        "tsConfigPath": "libs/e-commerce/tsconfig.lib.json"
      }
    },
    "gateway-server": {
      "type": "application",
      "root": "apps/gateway-server",
      "entryFile": "main",
      "sourceRoot": "apps/gateway-server/src",
      "compilerOptions": {
        "tsConfigPath": "apps/gateway-server/tsconfig.app.json"
      }
    },
    "backup": {
      "type": "library",
      "root": "libs/backup",
      "entryFile": "index",
      "sourceRoot": "libs/backup/src",
      "compilerOptions": {
        "tsConfigPath": "libs/backup/tsconfig.lib.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    }
  },
  "monorepo": true,
  "root": "apps/gateway-server"
}